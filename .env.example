# Polymarket Sports / Esports Trading Bot Configuration

# === Required for LIVE trading only ===
PRIVATE_KEY=           # Your Polygon wallet private key (0x...)
POLY_FUNDER=           # Your proxy/funder wallet address
POLY_SIGNATURE_TYPE=0  # 0=EOA, 1=POLY_PROXY (Magic Link email/Google), 2=GNOSIS_SAFE

# === Trading Parameters ===
# Tiny live canary example (keep only in local .env, not Git):
# BANKROLL=20
# MAX_TRADE_PCT=0.18
# MAX_TRADE_VALUE_USDC=2.50
# DAILY_RISK_BUDGET=4
# DAILY_LOSS_LIMIT=2
# ENABLE_SESSION_STOP_LOSS=true
# SESSION_STOP_LOSS_USDC=2
# MAX_POSITIONS=2
# DELAYED_ORDER_ALERT_SEC=120
# DELAYED_ORDER_RECHECK_SEC=15
BANKROLL=1000          # Total capital allocated (USDC)
STAKE_PCT=0.01         # Used only when copy mode is enabled
POLL_INTERVAL=15       # Seconds between each polling cycle (15s recommended)
ENTRY_RISK_PAUSE_LOG_SEC=300  # When hard risk stops pause new entry scanning, log at most this often
MAX_TRADERS=5          # Number of top traders to follow
MONITOR_FETCH_WORKERS=12  # Parallel activity fetchers so wider monitoring does not miss the signal window
LEADERBOARD_CATEGORY=SPORTS   # Polymarket leaderboard category used to discover candidates
LEADERBOARD_CANDIDATE_MULTIPLIER=6  # Fetch a wider pool, then keep only the safest MAX_TRADERS
LEADERBOARD_DISCOVERY_PERIODS=day,week,month  # Merge several leaderboard periods instead of only DAY
LEADERBOARD_DISCOVERY_ORDER_BY=pnl,vol  # Merge profit and volume leaderboards
MARKET_SCOPE=sports,esports   # Allowed markets: sports, esports, or all
ESPORT_SPORT_CODES=codmw,cs2,dota2,hok,lcs,lol,lpl,mlbb,ow,pubg,r6siege,rl,sc2,val,wildrift
MARKET_SCOPE_CACHE_SEC=3600   # Refresh sports metadata hourly

# === Mode ===
DRY_RUN=true           # true = research only, false = live trading
ENABLE_COPY_STRATEGY=false  # Keep copy-trading off by default
ENABLE_AUTONOMOUS_STRATEGY=true  # Default entry engine: autonomous sports/esports strategy
LIVE_RECORD_BLOCKED_SHADOW_SAMPLES=true  # In live mode, record blocked executable candidates as shadow-only research rows
LIVE_BLOCKED_SHADOW_MAX_OPEN=250  # Cap unsettled live shadow rows so research cannot bloat the runtime DB forever
LIVE_BLOCKED_SHADOW_COOLDOWN_SEC=3600  # Avoid recording the same blocked market/outcome every scan cycle
ENABLE_AUTONOMOUS_EDGE_FILTER_SHADOW=true  # During live loss quarantine, record esports and sports edge filters as no-money shadow only
AUTONOMOUS_EDGE_FILTER_MIN_PRICE=0.28
AUTONOMOUS_EDGE_FILTER_MAX_PRICE=0.42
AUTONOMOUS_EDGE_FILTER_TARGET_PRICE=0.34
AUTONOMOUS_EDGE_FILTER_MIN_LIQUIDITY=2000
AUTONOMOUS_EDGE_FILTER_MIN_LEAD_SEC=3600
AUTONOMOUS_EDGE_FILTER_MAX_LEAD_SEC=129600
AUTONOMOUS_EDGE_FILTER_MIN_SCORE=74
AUTONOMOUS_ESPORTS_EDGE_FILTER_MIN_PRICE=0.43  # v2 esports shadow: stop sampling low-price underdogs without external CLV
AUTONOMOUS_ESPORTS_EDGE_FILTER_MAX_PRICE=0.47
AUTONOMOUS_ESPORTS_EDGE_FILTER_TARGET_PRICE=0.46
AUTONOMOUS_ESPORTS_EDGE_FILTER_MIN_LIQUIDITY=5000
AUTONOMOUS_ESPORTS_EDGE_FILTER_MIN_LEAD_SEC=1800
AUTONOMOUS_ESPORTS_EDGE_FILTER_MAX_LEAD_SEC=43200
AUTONOMOUS_ESPORTS_EDGE_FILTER_MIN_SCORE=82
AUTONOMOUS_EDGE_FILTER_MAX_SIGNALS_PER_CYCLE=2
AUTONOMOUS_EDGE_FILTER_MIN_DECIDED_SAMPLES=50
AUTONOMOUS_EDGE_FILTER_ROLLBACK_MIN_DECIDED=30
AUTONOMOUS_EDGE_FILTER_ROLLBACK_MAX_WIN_RATE=0.45
ENABLE_COPY_ARCHIVE_SHADOW=true  # Continue the archived sports copy-trading strategy as no-money shadow while live stays quarantined
COPY_ARCHIVE_SHADOW_SCOPE=sports  # Restore only the scope that worked in the archive; esports copy stays excluded
COPY_ARCHIVE_SHADOW_TRADERS=0xd106952ebf30a3125affd8a23b6c1f30c35fc79c|Herdonia|85  # Tier-A archive seed
COPY_ARCHIVE_SHADOW_MAX_SIGNALS_PER_CYCLE=2
COPY_ARCHIVE_SHADOW_MAX_SIGNAL_AGE_SEC=900  # No-money copy simulation can observe slightly delayed Data API signals, then re-price from the current book
COPY_ARCHIVE_SHADOW_SIMULATED_MAX_TRADE_VALUE_USDC=3.00  # Paper-only cap that lets the shadow row clear 5-share sports books without touching live budget
COPY_ARCHIVE_SHADOW_MIN_DECIDED_SAMPLES=50
COPY_ARCHIVE_SHADOW_ROLLBACK_MIN_DECIDED=30
COPY_ARCHIVE_SHADOW_ROLLBACK_MAX_WIN_RATE=0.45
AUTONOMOUS_SPORT_CODES=dota2,cs2,lol,val,nfl,nba,mlb,nhl,epl,cfb,ncaab  # Search universe tags to scan
AUTONOMOUS_MIN_TRADE_VALUE_USDC=0.60  # Lower than this is usually not worth sending
AUTONOMOUS_MAX_TRADE_VALUE_USDC=2.50  # Tiny-bankroll ceiling that still leaves room for mid-priced 5-share markets
AUTONOMOUS_MIN_PRICE=0.26  # Avoid deep longshots by default
AUTONOMOUS_MAX_PRICE=0.50  # Allow more balanced favorites without drifting into near-certainties
AUTONOMOUS_TARGET_PRICE=0.38  # Prefer the sturdier middle of the band instead of cheap underdogs
AUTONOMOUS_MIN_MARKET_LIQUIDITY=750  # Skip thin books
AUTONOMOUS_MIN_EVENT_LEAD_SEC=900  # Avoid last-minute entries
AUTONOMOUS_MAX_EVENT_LEAD_SEC=172800  # Look ahead 48h so the bot can collect tomorrow's playable match markets too
AUTONOMOUS_MAX_CANDIDATES_PER_TAG=80  # Cap market fetch volume per tag
AUTONOMOUS_MAX_SIGNALS_PER_CYCLE=3  # Keep each scan cycle narrow
AUTONOMOUS_REQUIRE_ESPORTS_SERIES=true  # For esports require BO3 / BO5 style match winners
AUTONOMOUS_RETRY_COOLDOWN_SEC=1200  # Allow blocked or failed autonomous candidates to retry after 20m instead of permanently suppressing them
MIN_AUTONOMOUS_SCORE=68  # Minimum autonomous score before entry
ENABLE_AUTONOMOUS_LOSS_PROBATION=true  # Tighten autonomous concurrency after a poor live decision sample
AUTONOMOUS_LOSS_PROBATION_LOOKBACK_DAYS=3
AUTONOMOUS_LOSS_PROBATION_MIN_DECISIONS=8
AUTONOMOUS_LOSS_PROBATION_MAX_WIN_RATE=0.20
AUTONOMOUS_LOSS_PROBATION_MAX_OPEN_POSITIONS=1
ENABLE_AUTONOMOUS_LOSS_QUARANTINE=true  # Fully pause autonomous new entries after a severe live losing sample
AUTONOMOUS_LOSS_QUARANTINE_MIN_DECISIONS=8
AUTONOMOUS_LOSS_QUARANTINE_MAX_WIN_RATE=0.12
AUTONOMOUS_LOSS_QUARANTINE_MIN_REALIZED_LOSS_USDC=1.00
DRY_RUN_RECORD_BLOCKED_SAMPLES=true  # In DRY_RUN also journal blocked signals as shadow research samples
ENABLE_STAGE2_REPEAT_ENTRY_EXPERIMENT=false  # Keep repeat-entry paused by default until the old experiment is reviewed
REPEAT_ENTRY_EXPERIMENT_MAX_EXTRA_ENTRIES=1  # Cap the stage-2 experiment to one extra shadow re-entry per trader/market/outcome
ENABLE_STAGE2_NO_BOOK_DELAYED_RECHECK_EXPERIMENT=true  # Record a delayed recheck shadow experiment when the book is empty
NO_BOOK_DELAYED_RECHECK_DELAY_SEC=30  # Wait this long before re-checking whether the book becomes executable
NO_BOOK_DELAYED_RECHECK_MAX_EXTRA_ENTRIES=1  # Cap the delayed recheck experiment to one extra sample per trader/market/outcome
DELAYED_ORDER_ALERT_SEC=120  # Highlight delayed live orders once they remain unresolved past this threshold
DELAYED_ORDER_RECHECK_SEC=15  # Re-query delayed live orders on a short loop so matched/canceled states are written back
DELAYED_ORDER_RECHECK_LIMIT=10  # Cap how many delayed live orders are reconciled per cycle

# === Dry-Run Research Overrides ===
PAPER_BANKROLL=250     # Virtual bankroll used only in DRY_RUN sizing
PAPER_DAILY_RISK_BUDGET=250  # Virtual daily budget used only in DRY_RUN
PAPER_IGNORE_CAPITAL_GATES=true  # In DRY_RUN skip capital gates but keep quality/liquidity/anti-farming checks

# === Risk Controls ===
MAX_TRADE_PCT=0.05     # Max single trade as % of bankroll (5%)
MAX_TRADE_VALUE_USDC=0  # Optional absolute cap in USDC; 0 disables it. For tiny live bankrolls, values around 2.0-2.5 are often needed if you want safer mid-priced 5-share markets
DAILY_LOSS_LIMIT=50    # Default live loss cap anchor (used by SESSION_STOP_LOSS_USDC if not overridden)
ENABLE_SESSION_STOP_LOSS=true  # In LIVE mode, block new entries once realized + marked unrealized PnL breaches the stop
SESSION_STOP_LOSS_USDC=50  # Session stop threshold in USDC for real-money trading
SESSION_STOP_MODE=calendar_day  # Prefer a daily reset so the bot can resume collecting new live samples after JST midnight
SESSION_STOP_TIMEZONE=Asia/Tokyo  # Calendar-day resets use this timezone
SESSION_STOP_LOOKBACK_SEC=86400  # Used only when SESSION_STOP_MODE=trailing
ENABLE_GAME_MARKET_ACTIVE_EXIT=true  # For single-game sports/esports markets, allow proactive mirrored exits on sharp adverse moves
GAME_MARKET_ACTIVE_EXIT_PRICE_RATIO=0.70  # Trigger when mark <= entry_price * ratio
GAME_MARKET_ACTIVE_EXIT_ABS_DROP=0.15  # Or when mark <= entry_price - abs_drop
GAME_MARKET_ACTIVE_EXIT_COOLDOWN_SEC=60  # Cooldown between proactive exit attempts for the same position
ACTIVE_EXIT_MIN_SIZE_PENDING_RECHECK_SEC=900  # If a live exit is blocked only because sellable balance is below min_order_size, wait longer before retrying
ENABLE_AUTONOMOUS_PROTECTIVE_EXIT=true  # For autonomous non-single-game Match Winner positions, allow a gentle defensive exit before settlement
AUTONOMOUS_PROTECTIVE_EXIT_PRICE_RATIO=0.90  # Trigger earlier when mark <= entry_price * ratio
AUTONOMOUS_PROTECTIVE_EXIT_ABS_DROP=0.04  # Or when mark <= entry_price - abs_drop
AUTONOMOUS_PROTECTIVE_EXIT_MIN_LOSS_USDC=0.10  # On a tiny bankroll, a small real loss is enough to defend capital
ENABLE_AUTONOMOUS_TAKE_PROFIT=true  # For autonomous match-winner positions, allow proactive profit-taking before settlement
AUTONOMOUS_TAKE_PROFIT_PRICE_RATIO=1.20  # Trigger earlier when mark >= entry_price * ratio
AUTONOMOUS_TAKE_PROFIT_ABS_GAIN=0.05  # Or when mark >= entry_price + abs_gain
AUTONOMOUS_TAKE_PROFIT_MIN_PNL_USDC=0.10  # Small wins should still be banked on a tiny bankroll
MAX_POSITIONS=10       # Max concurrent open positions
DAILY_RISK_BUDGET=50   # Conservative cap on currently open deployed capital
MAX_TRADER_EXPOSURE_PCT=0.12  # Max bankroll exposure to one copied trader
MAX_MARKET_EXPOSURE_PCT=0.15  # Max bankroll exposure to one market/outcome
MIN_SIGNAL_CONFIRM_SEC=20  # Wait for a short confirmation window before mirroring
MAX_SIGNAL_AGE_SEC=90  # Ignore stale signals older than this
MIN_SIGNAL_PRICE=0.08  # Avoid chasing near-0 and near-1 contracts
MAX_SIGNAL_PRICE=0.92
TRADER_COOLDOWN_SEC=300  # Do not re-enter the same trader/market too quickly
WHIPSAW_LOOKBACK_SEC=900  # Skip traders who reverse the same market soon after entry
MAX_TRADER_MARKET_ENTRIES_PER_DAY=1  # Prevent repeated milking on the same market
ORDERBOOK_CACHE_SEC=2  # Short cache for public orderbook checks
MAX_ORDERBOOK_AGE_SEC=15  # Reject stale orderbook snapshots
LIVE_MARK_STALE_FALLBACK_SEC=3600  # Keep the last valid live mark around for drawdown visibility when orderbook/Gamma fetches blip
MAX_BOOK_SPREAD=0.03  # Skip books with spreads wider than 3 cents
MIN_TOP_LEVEL_LIQUIDITY_USDC=25  # Require usable top-of-book liquidity
MARKETABLE_BUY_MIN_VALUE_USDC=1.0  # Marketable BUY orders under about $1 are often rejected even if min_order_size is 5 shares
LIVE_EXIT_SAFE_MIN_ORDER_BUFFER_SHARES=0.25  # For live BUYs, require a small share buffer above min_order_size so future exits are less likely to get stuck below the sell minimum
DUST_POSITION_MAX_SIZE=0.01  # Hide tiny post-trade dust residuals from primary live position counts
DUST_POSITION_MAX_VALUE_USDC=0.01  # Ignore sub-cent residual notional in live dashboard/risk views
MAX_BOOK_PRICE_DRIFT=0.02  # Skip if current tradable price drifted too far from signal
MAX_BOOK_PRICE_IMPACT=0.02  # Skip if our size would walk too far through the book
SETTLEMENT_POLL_SEC=120  # How often to scan open journal entries for settled markets
SETTLEMENT_CACHE_SEC=30  # Cache closed-market snapshots briefly
SETTLEMENT_CANONICAL_EPS=0.02  # Treat prices near 0/0.5/1 as settlement payouts
SETTLEMENT_PROPOSED_EARLY_BUFFER_SEC=3600  # Allow proposed near-0/1 sports results to settle during the final hour

# === Trader Quality Filters ===
PROFILE_REFRESH_SEC=900  # Re-score tracked traders every 15 minutes
PROFILE_HISTORY_INTERVAL_SEC=1800  # Save trader status snapshots every 30 minutes unless risk/status changes sooner
MIN_TRADER_SCORE=60
MIN_RECENT_TRADES=8
MIN_COPYABLE_TRADE_USDC=10
MAX_MICRO_TRADE_RATIO=0.35
MAX_FLIP_RATE=0.25
MAX_BURST_TRADES_PER_60S=12
MAX_SAME_SECOND_TRADES=4

# === Conservative Consensus Strategy ===
ENABLE_CONSENSUS_STRATEGY=false  # Requires trader discovery; keep off when autonomous is the default engine
CONSENSUS_WINDOW_SEC=600
MIN_CONSENSUS_TRADERS=2
MIN_CONSENSUS_SCORE=72
CONSENSUS_TRADE_PCT=0.015

# === Reporting ===
REPORT_DEFAULT_DAYS=3  # Default lookback window for report.py
